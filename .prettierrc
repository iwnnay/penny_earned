{
    "useTabs": true,
    "singleQuote": true,
    "trailingComma": "none",
    "printWidth": 180,
    "bracketSpacing": true,
    "plugins": ["prettier-plugin-svelte"],
    "overrides": [
        {
            "files": "*.svelte",
            "options": {
                "parser": "svelte"
            }
        }
    ]
}
